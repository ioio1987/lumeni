{
  "Serilog": {
    "Using": [ "Serilog.Sinks.Console", "Serilog.Sinks.File", "Serilog.Sinks.Seq", "Serilog.Enrichers.Sensitive" ],
    "MinimumLevel": {
      "Default": "Debug",
      "Override": {
        "Microsoft": "Warning",
        "System": "Warning"
      }
    },
    "WriteTo": [
      {
        "Name": "Console",
        "Args": {
          "theme": "Serilog.Sinks.SystemConsole.Themes.AnsiConsoleTheme::Code, Serilog.Sinks.Console",
          "outputTemplate": "{Timestamp:HH:mm:ss.fff} {Level:u3} | cid:{ConversationId} fid:{ApplicationFlowName} tid:{ThreadId} | {SourceContext}{NewLine}{Message:lj}{NewLine}{Exception}"
        }
      },
      {
        "Name": "Seq",
        "Args": {
          "serverUrl": "http://seq:5341",
          "restrictedToMinimumLevel": "Debug"
        }
      },
      {
        "Name": "File",
        "Args": {
          "path": "Logs/log.txt",
          "rollingInterval": "Day",
          "rollOnFileSizeLimit": true,
          "formatter": "Serilog.Formatting.Compact.CompactJsonFormatter, Serilog.Formatting.Compact"
        }
      }
    ],
    "Enrich": [
      "FromLogContext",
      "WithMachineName",
      "WithThreadId",
      {
        "Name": "WithSensitiveDataMasking",
        "Args": {
          "options": {
            "MaskValue": "*****",
            "MaskProperties": [
              "Password",
              "ConfirmPassword"
            ],
            "Mode": "Globally"
          }
        }
      }
    ],
    "Destructure": [
      {
        "Name": "ToMaximumDepth",
        "Args": { "maximumDestructuringDepth": 4 }
      },
      {
        "Name": "ToMaximumStringLength",
        "Args": { "maximumStringLength": 100 }
      },
      {
        "Name": "ToMaximumCollectionCount",
        "Args": { "maximumCollectionCount": 10 }
      }
    ],
    "Properties": {
      "Application": "Syllogia.AuthServer"
    }
  },
  "AllowedHosts": "*",
  "Authority": "https://auth.syllogia.ge:94",
  "CorsAllowedOrigins": "http://localhost:4200;http://localhost:5001;http://test.syllogia.ge;",
  "ConnectionStrings": {
    "MSSQL_AuthServer": "Data Source=YOUR_SQL_HOST,1433;Initial Catalog=AuthServer;Integrated Security=false;User Id=YOUR_SQL_USER;Password=YOUR_SQL_PASSWORD;ApplicationIntent=ReadWrite;MultiSubnetFailover=False;MultipleActiveResultSets=true;Trust Server Certificate=true",
    "Postgres_AuthServer": "Host=postgres_db; Port=5432; Database=AuthServer; Username=admin; Password=Syllogia123"
  },
  "AuthMessageSenderOptions": {
    "SenderEmail": "no-reply@syllogia.ge"
  },
  "BrevoOptions": {
    "ApiKey": "YOUR_BREVO_API_KEY",
    "FromEmail": "no-reply@syllogia.ge",
    "FromName": "Syllogia",
    "TemplateId": 4
  },
  "RabbitMqOptions": {
    "Host": "erp_rabbitmq",
    "Port": 5672,
    "VirtualHost": "/",
    "UserName": "admin",
    "Password": "Syllogia123",
    "QueryDelay": 10
  }
}
